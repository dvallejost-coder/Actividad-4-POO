import tkinter as tk
from tkinter import messagebox


class ValidacionError(Exception):
    pass


class Programador:
    def __init__(self, nombre, apellidos):
        self.nombre = nombre
        self.apellidos = apellidos


class EquipoMaratonProgramacion:
    MAX_PROGRAMADORES = 3

    def __init__(self, nombre_equipo, universidad, lenguaje):
        self.validar_campo(nombre_equipo)
        self.validar_campo(universidad)
        self.validar_campo(lenguaje)

        self.nombre_equipo = nombre_equipo
        self.universidad = universidad
        self.lenguaje = lenguaje
        self.programadores = []

    def validar_campo(self, texto):
        if len(texto) > 20:
            raise ValidacionError(
                "La longitud no debe superar 20 caracteres."
            )

        for caracter in texto:
            if not (caracter.isalpha() or caracter.isspace()):
                raise ValidacionError(
                    "Solo se permiten letras y espacios."
                )

    def agregar_programador(self, programador):
        if self.esta_lleno():
            raise ValidacionError(
                "El equipo ya está completo."
            )

        self.programadores.append(programador)

    def esta_lleno(self):
        return len(self.programadores) == self.MAX_PROGRAMADORES

    def esta_completo(self):
        return len(self.programadores) >= 2
 
class Ventana:
    def __init__(self, root):
        self.root = root
        self.root.title("Maratón de Programación")

        self.equipo = None
        tk.Label(root, text="Nombre del equipo").grid(row=0, column=0)
        self.txt_equipo = tk.Entry(root)
        self.txt_equipo.grid(row=0, column=1)

        tk.Label(root, text="Universidad").grid(row=1, column=0)
        self.txt_universidad = tk.Entry(root)
        self.txt_universidad.grid(row=1, column=1)

        tk.Label(root, text="Lenguaje").grid(row=2, column=0)
        self.txt_lenguaje = tk.Entry(root)
        self.txt_lenguaje.grid(row=2, column=1)

        tk.Button(
            root,
            text="Crear Equipo",
            command=self.crear_equipo
        ).grid(row=3, column=0, columnspan=2, pady=5)

        tk.Label(root, text="Nombre").grid(row=4, column=0)
        self.txt_nombre = tk.Entry(root)
        self.txt_nombre.grid(row=4, column=1)

        tk.Label(root, text="Apellidos").grid(row=5, column=0)
        self.txt_apellidos = tk.Entry(root)
        self.txt_apellidos.grid(row=5, column=1)

        tk.Button(
            root,
            text="Agregar Programador",
            command=self.agregar_programador
        ).grid(row=6, column=0, columnspan=2, pady=5)

        self.lista = tk.Listbox(root, width=50)
        self.lista.grid(row=7, column=0, columnspan=2)

    def crear_equipo(self):
        try:
            self.equipo = EquipoMaratonProgramacion(
                self.txt_equipo.get(),
                self.txt_universidad.get(),
                self.txt_lenguaje.get()
            )

            messagebox.showinfo(
                "Éxito",
                "Equipo creado correctamente."
            )

        except ValidacionError as e:
            messagebox.showerror("Error", str(e))

    def agregar_programador(self):
        if self.equipo is None:
            messagebox.showerror(
                "Error",
                "Primero debe crear el equipo."
            )
            return

        try:
            nombre = self.txt_nombre.get()
            apellidos = self.txt_apellidos.get()

            self.equipo.validar_campo(nombre)
            self.equipo.validar_campo(apellidos)

            programador = Programador(nombre, apellidos)

            self.equipo.agregar_programador(programador)

            self.lista.insert(
                tk.END,
                f"{nombre} {apellidos}"
            )

            if self.equipo.esta_lleno():
                messagebox.showinfo(
                    "Equipo completo",
                    "El equipo tiene 3 integrantes."
                )

        except ValidacionError as e:
            messagebox.showerror("Error", str(e))



root = tk.Tk()
app = Ventana(root)
root.mainloop()
